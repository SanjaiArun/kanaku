# ---- Postgres ----
POSTGRES_ADMIN_PASSWORD=change_me_strong

# ---- Firefly III ----
# Generate APP_KEY with:
#   $rng = [System.Security.Cryptography.RandomNumberGenerator]::Create()
#   $bytes = New-Object byte[] 32; $rng.GetBytes($bytes)
#   "base64:" + [Convert]::ToBase64String($bytes)
FIREFLY_APP_KEY=
FIREFLY_STATIC_CRON_TOKEN=change_me_32_alphanumeric_chars

# ---- Firefly admin (one-time setup, used only by the gateway to auto-provision new users) ----
# The first user you register at http://localhost:8080 is automatically
# the Firefly owner/admin (see README Step 3). Generate a Personal
# Access Token for that same account (/profile/oauth) and put it here —
# the gateway uses it to create a brand-new, fully isolated Firefly
# user + PAT for every new Telegram user automatically, with no manual
# step per user. See gateway/firefly_admin.py for how.
FIREFLY_ADMIN_PAT=
# Base URL the gateway uses when provisioning new accounts; the
# per-profile firefly_base_url stored in the DB is set from this.
FIREFLY_BASE_URL=http://firefly_iii:8080

# ---- n8n (optional — only needed if you use n8n for other workflows) ----
N8N_ENCRYPTION_KEY=change_me_random_string
N8N_ADMIN_USER=admin
N8N_ADMIN_PASSWORD=change_me_strong

# ---- Telegram ----
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=get_from_botfather

# ---- Groq (LLM API — free tier available at console.groq.com) ----
# The gateway runs a tool-calling LangGraph agent, so the model needs
# decent tool-use support. On the free tier, llama-3.3-70b-versatile is
# more reliable at tool calling but has a much lower daily token cap
# (~25 turns/day at this system prompt's size before a 24h lockout);
# llama-3.1-8b-instant has a far higher cap and is fine now that batched/
# invalid tool calls are rejected in code rather than relying on the
# model to follow instructions perfectly.
GROQ_API_KEY=get_from_groq_console
GROQ_MODEL=llama-3.1-8b-instant

# Each Groq model has its own separate daily token quota. When GROQ_MODEL
# hits a rate limit (429), the agent automatically retries with the next
# model in this comma-separated list, in order, before giving up — so a
# quota exhaustion on one model doesn't take the bot down. Leave unset to
# use the default chain below.
# GROQ_MODEL_FALLBACKS=llama-3.3-70b-versatile,openai/gpt-oss-20b,meta-llama/llama-4-scout-17b-16e-instruct

# ---- Gemini (optional extra fallback tier — free tier at aistudio.google.com) ----
# A different provider means a completely separate quota pool from Groq,
# so this is the last resort once every Groq model above is exhausted.
# Only used if GOOGLE_API_KEY is set; leave both blank to skip it
# entirely and rely on Groq alone.
GOOGLE_API_KEY=
# GEMINI_MODEL_FALLBACKS=gemini-2.5-flash-lite,gemini-2.5-flash
